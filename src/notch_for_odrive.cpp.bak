

// First, we need to give the Controller class a place to store these coefficients. 
// Add this to your Controller class definition:

// In controller.hpp, inside the Controller class
struct NotchConfig {
    float b0 = 1.0f, b1 = 0, b2 = 0, a1 = 0, a2 = 0;
    float x1 = 0, x2 = 0, y1 = 0, y2 = 0;
    bool enabled = false;
} notch_;

// Add a function to reset the filter memory (crucial when changing coeffs)
void reset_notch() {
    notch_.x1 = notch_.x2 = notch_.y1 = notch_.y2 = 0;
}

